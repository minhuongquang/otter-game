; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SariaMod"
config/description="A 2D RPG + Visual Novel Hybrid"
run/main_scene="res://scenes/world/boot.tscn"
config/features=PackedStringArray("4.7")

[autoload]

EventBus="*res://autoload/event_bus.gd"
Database="*res://autoload/database.gd"
SaveManager="*res://autoload/save_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
InputManager="*res://autoload/input_manager.gd"
UIManager="*res://autoload/ui_manager.gd"
SceneManager="*res://autoload/scene_manager.gd"
GlobalFlags="*res://autoload/global_flags.gd"
VNManager="*res://scripts/managers/vn/vn_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"

